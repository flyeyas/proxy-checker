HOST_PORT=8888
PROXY_HOST_BIND=127.0.0.1
PROXY_HOST_PORT=7890
PROXY_GATEWAY_ENABLED=true
PROXY_GATEWAY_GRADES=A,B
PROXY_GATEWAY_TOKEN=
PROXY_GATEWAY_TIMEOUT=20
VERSION=v0.1.1
IMAGE_NAME=proxy-forge
IMAGE=ghcr.io/flyeyas/proxy-forge:v0.1.1
PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
AUTH_PASSWORD=change-me
AUTH_SESSION_DAYS=7
CHECK_ROUNDS=2
MAX_CHECK_ROUNDS=3
MAX_CONCURRENT=30
MAX_CONCURRENT_LIMIT=200
TIMEOUT=12
DETECT_TIMEOUT=8
LOG_LIMIT=100
APP_TIMEZONE=Asia/Shanghai
