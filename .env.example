HOST_PORT=8888
IMAGE=ghcr.io/strongshuai/proxy-checker:latest
PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
AUTH_PASSWORD=change-me
AUTH_SESSION_DAYS=7
CHECK_ROUNDS=2
MAX_CHECK_ROUNDS=3
MAX_CONCURRENT=30
MAX_CONCURRENT_LIMIT=200
TIMEOUT=12
DETECT_TIMEOUT=8
RUN_LOG_LIMIT=100
APP_TIMEZONE=Asia/Shanghai
